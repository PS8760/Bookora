// schema.prisma — v2 (Production Grade)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../app/generated/prisma"
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, pg_trgm] // uuid generation + text search
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  CUSTOMER
  ORGANISER
  ADMIN
}

enum AppointmentType {
  USER_BASED
  RESOURCE_BASED
}

enum ScheduleType {
  WEEKLY
  FLEXIBLE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum AssignmentMode {
  AUTOMATIC
  MANUAL
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum QuestionType {
  TEXT
  MULTIPLE_CHOICE
  BOOLEAN
  NUMBER
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum AuditAction {
  CREATED
  UPDATED
  CANCELLED
  CONFIRMED
  RESCHEDULED
  PAYMENT_RECEIVED
  PAYMENT_REFUNDED
}

// ─────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  otpVerified  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  providerProfile   ProviderProfile?
  customerBookings  Booking[]        @relation("CustomerBookings")
  providerBookings  Booking[]        @relation("ProviderBookings")
  organisedServices Service[]
  providerSlots     ProviderSlot[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([role, isActive])
}

// Extension table for organiser/admin-specific metadata
model ProviderProfile {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  bio       String?
  avatarUrl String?
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Indexed on email for fast OTP lookups
model OtpVerification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, used])
  @@index([expiresAt])
}

// ─────────────────────────────────────────
// RESOURCES
// ─────────────────────────────────────────

model Resource {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providerSlots ProviderSlot[]
  bookings      Booking[]

  @@index([isActive])
}

// ─────────────────────────────────────────
// SERVICES (Appointment Types)
// ─────────────────────────────────────────

model Service {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organiserId     String          @db.Uuid
  title           String
  description     String?
  durationMinutes Int
  type            AppointmentType
  isPublished     Boolean         @default(false)
  shareToken      String?         @unique
  advancePayment  Boolean         @default(false)
  paymentAmount   Decimal?        @db.Decimal(10, 2)
  currency        String          @default("USD")
  manualConfirm   Boolean         @default(false)
  assignmentMode  AssignmentMode  @default(AUTOMATIC)
  maxPerSlot      Int             @default(1)
  venue           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime? // soft delete

  organiser     User           @relation(fields: [organiserId], references: [id])
  schedules     Schedule[]
  questions     Question[]
  providerSlots ProviderSlot[]
  bookings      Booking[]

  @@index([organiserId, isPublished])
  @@index([deletedAt])
}

// ─────────────────────────────────────────
// SCHEDULES & AVAILABILITY RULES
// ─────────────────────────────────────────

model Schedule {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String       @db.Uuid
  type      ScheduleType
  createdAt DateTime     @default(now())

  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  weeklyRules  WeeklyRule[]
  flexibleDays FlexibleDay[]

  @@index([serviceId])
}

// Store times as proper Int minutes-since-midnight for reliable comparisons
model WeeklyRule {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId  String @db.Uuid
  dayOfWeek   Int // 0=Sunday … 6=Saturday
  startMinute Int // minutes since midnight, e.g. 540 = 09:00
  endMinute   Int // e.g. 1020 = 17:00

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, dayOfWeek])
}

model FlexibleDay {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId  String   @db.Uuid
  date        DateTime @db.Date
  startMinute Int
  endMinute   Int

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, date])
}

// ─────────────────────────────────────────
// PROVIDER SLOTS
// ─────────────────────────────────────────

model ProviderSlot {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId  String   @db.Uuid
  userId     String?  @db.Uuid // set when type = USER_BASED
  resourceId String?  @db.Uuid // set when type = RESOURCE_BASED
  startTime  DateTime
  endTime    DateTime
  capacity   Int      @default(1)
  booked     Int      @default(0)
  version    Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  service  Service   @relation(fields: [serviceId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  resource Resource? @relation(fields: [resourceId], references: [id])
  bookings Booking[]

  @@index([serviceId, startTime, endTime])
  @@index([userId, startTime])
  @@index([resourceId, startTime])
  @@index([serviceId, isActive, startTime])
}

// ─────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────

model Booking {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId     String        @db.Uuid
  serviceId      String        @db.Uuid
  providerSlotId String        @db.Uuid
  userId         String?       @db.Uuid
  resourceId     String?       @db.Uuid
  status         BookingStatus @default(PENDING)
  paymentStatus  PaymentStatus @default(UNPAID)
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer      User            @relation("CustomerBookings", fields: [customerId], references: [id])
  service       Service         @relation(fields: [serviceId], references: [id])
  providerSlot  ProviderSlot    @relation(fields: [providerSlotId], references: [id])
  provider      User?           @relation("ProviderBookings", fields: [userId], references: [id])
  resource      Resource?       @relation(fields: [resourceId], references: [id])
  answers       BookingAnswer[]
  payments      Payment[]
  reschedules   RescheduleLog[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@unique([providerSlotId, customerId])
  @@index([customerId, status])
  @@index([providerSlotId, status])
  @@index([serviceId, status])
  @@index([userId, status])
  @@index([createdAt])
}

// Audit trail for reschedule events
model RescheduleLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String   @db.Uuid
  fromSlotId      String   @db.Uuid
  toSlotId        String   @db.Uuid
  rescheduledById String   @db.Uuid // who triggered it
  reason          String?
  createdAt       DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

// ─────────────────────────────────────────
// QUESTIONS & ANSWERS
// ─────────────────────────────────────────

model Question {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String       @db.Uuid
  text      String
  type      QuestionType
  required  Boolean      @default(false)
  order     Int
  createdAt DateTime     @default(now())

  service Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers BookingAnswer[]

  @@index([serviceId, order])
}

// Replaces String[] with a proper relational table
model QuestionOption {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String @db.Uuid
  label      String
  order      Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
}

model BookingAnswer {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId        String  @db.Uuid
  questionId       String  @db.Uuid
  answerText       String?
  selectedOptionId String? @db.Uuid // for MULTIPLE_CHOICE

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([bookingId, questionId])
  @@index([bookingId])
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String        @db.Uuid
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  gatewayProvider String? // "stripe", "razorpay", etc.
  gatewayRef      String?       @unique // gateway transaction ID
  idempotencyKey  String        @unique
  paidAt          DateTime?
  refundedAt      DateTime?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String              @db.Uuid
  bookingId     String?             @db.Uuid
  channel       NotificationChannel
  status        NotificationStatus  @default(QUEUED)
  subject       String?
  body          String
  sentAt        DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())

  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId, status])
  @@index([bookingId])
  @@index([createdAt, status])
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId   String      @db.Uuid
  bookingId String?     @db.Uuid
  action    AuditAction
  metadata  Json? // snapshot of changed fields
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  actor   User     @relation(fields: [actorId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([actorId])
  @@index([bookingId])
  @@index([createdAt])
}
